# Zev — Environment Variables Example
# Copy this file to .env and fill in your real values.
# NEVER commit the real .env file — it contains secrets.

# Database — PostgreSQL (required for Netlify/serverless deployments)
# Get a free Postgres database from https://neon.tech
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.neon.tech/zev?sslmode=require

# Email (Hotmail / Outlook SMTP)
SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=zevdevsup@hotmail.com
SMTP_PASS=your-hotmail-password
SMTP_FROM=zevdevsup@hotmail.com
SMTP_FROM_NAME=Zev
